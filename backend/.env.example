# Puerto HTTP del servidor
PORT=3011

# Modo real: providers según keys. Si es false, respuesta simulada.
ENABLE_REAL_PROVIDERS=true

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI Text-to-Speech (voz natural del asistente)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Google Places API (New)
GOOGLE_PLACES_API_KEY=

# MySQL — si DB_HOST está definido, el registro/login es obligatorio
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=retailso_aroundme
DB_PASSWORD=cambiar_esta_clave
DB_NAME=retailso_aroundme

# Secreto para tokens de sesión (generar uno largo y aleatorio en producción)
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
